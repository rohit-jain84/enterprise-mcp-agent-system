# OpenAI API
OPENAI_API_KEY=your-key-here

# Database
# For local development (outside Docker): use localhost
# For Docker Compose: change localhost to "postgres" (the service name)
DATABASE_URL=postgresql+asyncpg://agent:agent_dev@localhost:5432/agent_db
POSTGRES_DB=agent_db
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# MCP Servers
GITHUB_MCP_URL=http://localhost:8001
PROJECT_MGMT_MCP_URL=http://localhost:8002
CALENDAR_MCP_URL=http://localhost:8003

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=enterprise-mcp-agent

# Guardrails
GUARDRAILS_ENABLED=true
